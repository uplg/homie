# Twitch ----
# Client ID of the Twitch application (https://dev.twitch.tv/console/apps).
# The application must be registered as a "Public client" to enable the Device Code Flow.
TWITCH_CLIENT_ID=

# Login (lowercase channel name) of the broadcaster the bot listens to.
TWITCH_BROADCASTER_LOGIN=

# Maison ----
# Root URL of the Maison backend, without the /api suffix.
MAISON_BASE_URL=http://192.168.1.2:3033

# Credentials used for POST /api/auth/login.
MAISON_USERNAME=
MAISON_PASSWORD=

# Optional ----
# Directory where the bot persists its Twitch token and other local state.
TWITCHY_STATE_DIR=./.twitchy

# Path to the TOML file that maps rewards/commands to actions.
REWARDS_FILE=config/rewards.toml

# Optional: substring matched (case-insensitive) against macOS output device
# names. The first match becomes the audio output the bot writes !yt tracks
# to. Use this to route the bot through BlackHole so OBS can capture it
# independently of the system mix. The bot logs the device list on startup;
# pick any unique substring of the entry you want.
# Example:
#   TWITCHY_AUDIO_DEVICE=BlackHole
TWITCHY_AUDIO_DEVICE=

# Log level (see tracing-subscriber EnvFilter).
RUST_LOG=twitchy=info
