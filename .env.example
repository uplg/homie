# Twitch ----
# Client ID of the Twitch application (https://dev.twitch.tv/console/apps).
# The application must be registered as a "Public client" to enable the Device Code Flow.
TWITCH_CLIENT_ID=

# Login (lowercase channel name) of the broadcaster the bot listens to.
TWITCH_BROADCASTER_LOGIN=

# Maison ----
# Root URL of the Maison backend, without the /api suffix.
MAISON_BASE_URL=http://192.168.1.2:3033

# Credentials used for POST /api/auth/login.
MAISON_USERNAME=
MAISON_PASSWORD=

# Optional ----
# Directory where the bot persists its Twitch token and other local state.
TWITCHY_STATE_DIR=./.twitchy

# Path to the TOML file that maps rewards/commands to actions.
REWARDS_FILE=config/rewards.toml

# Optional: substring matched (case-insensitive) against macOS output device
# names. The first match becomes the audio output the bot writes !yt tracks
# to. Use this to route the bot through BlackHole so OBS can capture it
# independently of the system mix. The bot logs the device list on startup;
# pick any unique substring of the entry you want.
# Example:
#   TWITCHY_AUDIO_DEVICE=BlackHole
TWITCHY_AUDIO_DEVICE=

# Optional: starting volume of the music queue (0-100). Defaults to 80.
# Viewers/admins can still change it at runtime with !volume.
# Example:
#   TWITCHY_INITIAL_VOLUME=42
TWITCHY_INITIAL_VOLUME=

# Optional: URL the !club chat command echoes back. When unset, !club is
# disabled (not advertised, no reply).
# Example:
#   TWITCHY_CLUB_URL=https://discord.gg/your-invite
TWITCHY_CLUB_URL=

# Optional: URL the !discord chat command echoes back. When unset, !discord is
# disabled (not advertised, no reply).
# Example:
#   TWITCHY_DISCORD_URL=https://discord.gg/your-invite
TWITCHY_DISCORD_URL=

# Optional OBS WebSocket configuration for the !screen admin command.
# When OBS_WS_HOST and OBS_SOURCES are both unset, !screen is disabled.
# Set OBS_SOURCES to the comma-separated list of capture source names
# (typically macOS Screen Capture / Display / Window Capture inputs)
# you want !screen to force-restart.
# Example:
#   OBS_WS_HOST=127.0.0.1
#   OBS_WS_PORT=4455
#   OBS_WS_PASSWORD=secret
#   OBS_SOURCES=Display 1,Display 2
OBS_WS_HOST=
OBS_WS_PORT=4455
OBS_WS_PASSWORD=
OBS_SOURCES=screen

# Optional automatic capture-freeze monitor. When enabled, the bot polls
# every OBS source listed in OBS_SOURCES via the OBS screenshot API and
# force-restarts any source whose screenshot stops changing for
# OBS_MONITOR_FREEZE_THRESHOLD consecutive checks. Set to true/1/yes/on
# to opt in. Defaults: 60s interval, threshold 2, 30s post-restart cooldown.
# Example:
#   OBS_MONITOR_ENABLED=true
#   OBS_MONITOR_INTERVAL_SECS=60
#   OBS_MONITOR_FREEZE_THRESHOLD=2
#   OBS_MONITOR_COOLDOWN_SECS=30
OBS_MONITOR_ENABLED=
OBS_MONITOR_INTERVAL_SECS=60
OBS_MONITOR_FREEZE_THRESHOLD=2
OBS_MONITOR_COOLDOWN_SECS=30

# Log level (see tracing-subscriber EnvFilter).
RUST_LOG=twitchy=info
